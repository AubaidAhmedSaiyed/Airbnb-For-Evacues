<% layout("/layouts/boilerplate") %>
<body>
  <div class="main">
    <section>
      <div class="Hero">
        <h2>Your bridge to safety in uncertain times. Whether you need a place to stay or want to offer one</h2>
        <h3>we connect evacuees and caring hosts with ease and compassion.</h3>
        <a href="/evacuee/shelters"><button>Find Shelter</button></a>

        <section class="howit">
          <h2>How You Can Be Part of the Solution</h2>
          <div class="steps-card">
            <div class="steps">
              <h3>1. Create an Account</h3>
              <p>Sign up as an evacuee or a host. It only takes a minute.</p>
            </div>
          </div>
          <div class="steps-card">
            <div class="steps">
              <h3>2. Find or List a Shelter</h3>
              <p>Evacuees browse nearby shelters. Hosts can list safe and available spaces.</p>
            </div>
          </div>
          <div class="steps-card">
            <div class="steps">
              <h3>3. Connect & Stay Safe</h3>
              <p>Send or accept a request. Sheltr handles the rest with care and privacy.</p>
            </div>
          </div>
        </section>

        <section class="why">
          <h2>Built for People. Not for Profit.</h2>
          <ul>
            <li>✅ 100% free — for evacuees, hosts, and communities</li>
            <li>✅ Run by volunteers and technologists, not businesses</li>
            <li>✅ Focused on dignity, privacy, and safety</li>
            <li>✅ Supporting disaster-hit communities across the nation</li>
          </ul>
        </section>

        <section class="stories">
          <h2>Voices from the Ground</h2>
          <div class="testimonial">
            <p>“I was scared and alone during the floods. A stranger on Sheltr became family overnight.”</p>
            <strong>– John, Evacuee in Japan</strong>
          </div>
          <div class="testimonial">
            <p>“Offering a room wasn’t much, but it meant the world to someone. Sheltr made it simple and human.”</p>
            <strong style="margin-bottom: 0;">– Rehan, Host in Egypt</strong>
          </div>
        </section>
      </div>
    </section>
  </div>

  <p><strong><%= message %></strong></p>
</body>