<% layout("/layouts/boilerplate") %>
<body>
    <h2>Host A Shelter</h2>
    <form action="/volunteer" method="POST">
        <label for="title">Title:</label>
        <input type="text" id="title" name="title" required>
        <br>

        <label for="description">Description:</label>
        <textarea id="description" name="description" rows="4" required></textarea>
        <br>

        <label for="image">Shelter Image URL (optional):</label>
        <input type="text" id="image" name="image" placeholder="https://...">
        <br>

        <label for="address">Address:</label>
        <input type="text" id="address" name="address" required>
        <br>

        <label for="country">Country:</label>
        <input type="text" id="country" name="country" required>
        <br>

        <label for="price">Price (optional):</label>
        <input type="number" id="price" name="price" min="0" step="1" placeholder="0">
        <br>

        <label for="capacity">Capacity:</label>
        <input type="number" id="capacity" name="capacity" min="1" step="1" required>
        <br>

        <label for="availableFrom">Available From:</label>
        <input type="date" id="availableFrom" name="availableFrom">
        <br>

        <label for="availableUntil">Available Until:</label>
        <input type="date" id="availableUntil" name="availableUntil">
        <br><br>

        <button type="submit">Create Shelter</button>
    </form>

    
</body>
