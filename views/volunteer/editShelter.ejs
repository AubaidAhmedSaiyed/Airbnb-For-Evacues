<% layout("/layouts/boilerplate") %>
<body>
    <h2>Edit Shelter</h2>
    <form action="/volunteer/myShelter/<%= listing._id %>" method="POST">
        <label for="title">Title:</label>
        <input type="text" id="title" name="title" value="<%= listing.title %>" required>
        <br>

        <label for="description">Description:</label>
        <textarea id="description" name="description" rows="4" required><%= listing.description %></textarea>
        <br>

        <label for="image">Shelter Image URL (optional):</label>
        <input type="text" id="image" name="image" value="<%= (listing.images && listing.images.length) ? listing.images[0] : '' %>">
        <br>

        <label for="address">Address:</label>
        <input type="text" id="address" name="address" value="<%= listing.location.address %>" required>
        <br>

        <label for="country">Country:</label>
        <input type="text" id="country" name="country" value="<%= listing.location.country %>" required>
        <br>

        <label for="price">Price (optional):</label>
        <input type="number" id="price" name="price" min="0" step="1" value="<%= listing.price || 0 %>">
        <br>

        <label for="capacity">Capacity:</label>
        <input type="number" id="capacity" name="capacity" min="1" step="1" value="<%= listing.capacity %>" required>
        <br>

        <label for="availableFrom">Available From:</label>
        <input type="date" id="availableFrom" name="availableFrom" value="<%= listing.availableFrom ? listing.availableFrom.toISOString().slice(0,10) : '' %>">
        <br>

        <label for="availableUntil">Available Until:</label>
        <input type="date" id="availableUntil" name="availableUntil" value="<%= listing.availableUntil ? listing.availableUntil.toISOString().slice(0,10) : '' %>">
        <br><br>

        <button type="submit">Save Changes</button>
    </form>

    <form action="/volunteer/myShelter/<%= listing._id %>/delete" method="POST" style="margin-top: 10px;">
      <button type="submit">Delete Shelter</button>
    </form>

    
</body>
