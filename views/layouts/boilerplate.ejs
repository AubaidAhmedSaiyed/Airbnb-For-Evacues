<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style/index.css">
</head>
<body>
    <div class="main-nav">
        <nav class="navbar">
            <h3 class="logo" style="margin:0; padding-left:10px;">
              <a href="/" style="color:white; text-decoration:none;">Sheltr</a>
            </h3>
            <div class="tagline">
                 <span>A Place to Rest, A Path to Rebuild</span>
            </div>

            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/evacuee/shelters">Shelters</a></li>
                <li data-role="host" data-auth="logged-in"><a href="/volunteer">Host Dashboard</a></li>
                <li class="pill" data-whoami>Not logged in</li>
                <a href="/evacuee/bookings" data-auth="logged-in"><button>My Bookings</button></a>
                <a href="/volunteer/myShelter" data-role="host" data-auth="logged-in"><button>My Shelters</button></a>
                <a href="/login" data-auth="logged-out"><button>Login</button></a>
                <a href="/signup" data-auth="logged-out"><button>Sign Up</button></a>
                <button type="button" data-auth="logged-in" onclick="window.Sheltr.logout()">Logout</button>
            </ul>
        </nav>
    </div>
    <div class="container">
        <%- body %>
    </div>

    <script src="/js/client.js"></script>
</body>
</html>